#!/bin/bash
# erch:summary=Run e2e verification tests (Go)
# erch:examples=erch test | erch test --quiet

set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/eande/eande-os/dotfiles}"
QUIET=false

for arg in "$@"; do
  case "$arg" in
    --quiet|-q) QUIET=true ;;
  esac
done

if [ "$QUIET" = true ]; then
  exec go test "$DOTFILES_DIR/tests/..." -count=1 2>&1 | grep -E "^(ok|FAIL|---)"
else
  exec go test "$DOTFILES_DIR/tests/..." -v -count=1
fi
