#!/bin/bash
# erch:summary=Verify docs match actual configuration state
# erch:examples=erch docs-verify

set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/eande/eande-os/dotfiles}"
FAILED=0

check() {
  local label="$1" file="$2" pattern="$3"
  if grep -q "$pattern" "$file" 2>/dev/null; then
    echo "  PASS: $label"
  else
    echo "  FAIL: $label — pattern '$pattern' not in $file"
    FAILED=$((FAILED + 1))
  fi
}

check_file() {
  local label="$1" path="$2"
  if [ -f "$path" ]; then
    echo "  PASS: $label"
  else
    echo "  FAIL: $label — not found: $path"
    FAILED=$((FAILED + 1))
  fi
}

echo ""
echo "── Config file existence (Layer 3) ──"
check_file "hyprland.conf" "$DOTFILES_DIR/home/.config/hypr/hyprland.conf"
check_file "bindings.conf" "$DOTFILES_DIR/home/.config/hypr/bindings.conf"
check_file "waybar/config.jsonc" "$DOTFILES_DIR/home/.config/waybar/config.jsonc"
check_file "ags/README.md (repo desc matches)" "$DOTFILES_DIR/README.md"

echo ""
echo "── erch-* commands metadata ──"
for cmd in "$DOTFILES_DIR/home/.local/bin/erch-"*; do
  name=$(basename "$cmd")
  if head -1 "$cmd" | grep -q "^#!/"; then
    if grep -q "erch:summary=" "$cmd" 2>/dev/null; then
      echo "  PASS: $name has summary"
    else
      echo "  FAIL: $name missing erch:summary"
      FAILED=$((FAILED + 1))
    fi
  fi
done

echo ""
echo "── Docs coherency ──"
check "AGENTS.md mentions user branch" "$DOTFILES_DIR/../AGENTS.md" "user branch"
check "dotfiles/README.md mentions make targets" "$DOTFILES_DIR/README.md" "make deploy"
check "plan.md references layer model" "$DOTFILES_DIR/../plan.md" "Layer 0"

echo ""
if [ "$FAILED" -eq 0 ]; then
  echo "  All checks passed"
  exit 0
else
  echo "  $FAILED check(s) failed"
  exit 1
fi
