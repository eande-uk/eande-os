#!/bin/bash
# omarchy:summary=Sync system packages via Layer Zero (install/remove)
# omarchy:group=os-conf
# omarchy:name=layer-zero
# omarchy:examples=omarchy os-conf layer-zero | omarchy os-conf layer-zero --dry-run

set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/eande/os-conf/dotfiles}"

exec make -C "$DOTFILES_DIR" layer-zero "$@"
