#!/usr/bin/env bash
# omarchy:summary=Render Mermaid diagrams via Docker (minlag/mermaid-cli)
# omarchy:group=os-conf
# omarchy:name=mmd
# omarchy:examples=omarchy os-conf mmd flow.mmd

set -euo pipefail

usage() {
  cat <<EOF
omarchy os-conf mmd — Render Mermaid diagrams via Docker

Usage:
  omarchy os-conf mmd <input> [<output>] [-- <extra mmdc args>...]
  omarchy os-conf mmd --help

Examples:
  omarchy os-conf mmd flow.mmd
  omarchy os-conf mmd flow.mmd diagram.png -- -t neutral -b transparent
  omarchy os-conf mmd README.md

Notes:
  - Input/output are relative to diagrams directory (default: current dir)
  - Set DIAGRAMS_DIR to override
  - Args after -- are forwarded to mermaid-cli (mmdc)
EOF
  exit 0
}

[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && usage

command -v docker >/dev/null 2>&1 || { gum style --foreground "#BF616A" "Docker not found"; exit 1; }

IN="${1:-README.md}"
shift 2>/dev/null || true

OUT=""
if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then
  OUT="$1"; shift 2>/dev/null || true
fi
[[ -z "$OUT" ]] && OUT="${IN%.*}.svg"

DIR="${DIAGRAMS_DIR:-.}"
DIR_ABS="$(realpath "$DIR" 2>/dev/null)" || { gum style --foreground "#BF616A" "Directory not found: $DIR"; exit 1; }

gum spin --spinner dot --title "Rendering $IN → $OUT" -- \
  docker run --rm -u "$(id -u):$(id -g)" -v "$DIR_ABS:/data" minlag/mermaid-cli -i "/data/$IN" -o "/data/$OUT" "${@:---}"

gum style --foreground "#A3BE8C" "  Wrote $OUT"
