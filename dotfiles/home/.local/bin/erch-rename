#!/usr/bin/env bash
# erch:summary=Rename files selected by fd
# erch:examples=erch rename OLD NEW --confirm

set -euo pipefail

usage() {
  cat <<EOF
erch rename — Rename files selected by fd

Usage:
  erch rename OLD NEW [options] [-- fd-args...]

Options:
  --confirm       show diff and prompt before applying
  --first-only    replace only first OLD occurrence per filename
  --dry-run-off   apply immediately (no prompt)
  -h, --help      show this help

Examples:
  erch rename OLD NEW                    dry run
  erch rename OLD NEW --confirm          prompt before apply
  erch rename OLD NEW -g '*.txt'         dry run with fd glob
  erch rename OLD NEW --first-only       replace first per filename
EOF
  exit 0
}

confirm=false
dry_run=true
first_only=false
fd_args=()

[[ $# -lt 2 ]] && usage

OLD="$1"
NEW="$2"
shift 2

while (("$#")); do
  case "$1" in
    --confirm)     confirm=true; dry_run=true; shift ;;
    --dry-run-off) dry_run=false; shift ;;
    --first-only)  first_only=true; shift ;;
    --help|-h)     usage ;;
    --)            shift; fd_args+=("$@"); break ;;
    *)             fd_args+=("$1"); shift ;;
  esac
done

fd_cmd=(fd -0 "$OLD" "${fd_args[@]}")

declare -a srcs dsts
while IFS= read -r -d '' file; do
  dir="${file%/*}"
  base="${file##*/}"
  if $first_only; then newbase="${base/$OLD/$NEW}"; else newbase="${base//"$OLD"/"$NEW"}"; fi
  [[ "$newbase" == "$base" ]] && continue
  srcs+=("$file")
  dsts+=("$dir/$newbase")
done < <("${fd_cmd[@]}" 2>/dev/null || true)

if ((${#srcs[@]} == 0)); then
  gum style --foreground "#EBCB8B" "No matching files to rename."
  exit 0
fi

echo
gum style --foreground "#88C0D0" "Planned renames (${#srcs[@]} files):"
for i in "${!srcs[@]}"; do
  printf '  mv  %q  →  %q\n' "${srcs[i]}" "${dsts[i]}"
done

if $dry_run; then
  if $confirm; then
    echo
    if ! gum confirm "Apply ${#srcs[@]} renames?"; then
      gum style --foreground "#EBCB8B" "Aborted."
      exit 0
    fi
  else
    echo
    gum style --foreground "#81A1C1" "Dry run. Use --confirm or --dry-run-off to apply."
    exit 0
  fi
fi

applied=0
skipped=0
for i in "${!srcs[@]}"; do
  if [[ -e "${dsts[i]}" ]]; then
    gum style --foreground "#BF616A" "  SKIP: target exists → ${dsts[i]}"
    ((skipped++))
    continue
  fi
  mkdir -p "$(dirname "${dsts[i]}")"
  if mv -- "${srcs[i]}" "${dsts[i]}"; then
    printf '  \033[0;32mRENAMED\033[0m  %q\n' "${dsts[i]}"
    ((applied++))
  else
    gum style --foreground "#BF616A" "  ERROR: ${srcs[i]}"
  fi
done

gum style --foreground "#A3BE8C" "Done — ${applied} renamed, ${skipped} skipped"
