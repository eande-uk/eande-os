#!/bin/bash
# omarchy:summary=Deploy dotfiles configs to $HOME via stow
# omarchy:group=os-conf
# omarchy:name=deploy
# omarchy:examples=omarchy os-conf deploy | omarchy os-conf deploy --dry-run

set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/eande/os-conf/dotfiles}"

exec make -C "$DOTFILES_DIR" deploy "$@"
