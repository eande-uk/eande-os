#!/bin/bash
# erch:summary=Convert Markdown to standalone styled HTML via erch wiki
# erch:examples=erch md-to-html input.md [output.html]

set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  cat <<'EOF'
erch md-to-html — Convert Markdown to standalone styled HTML

Usage:
  erch md-to-html input.md [output.html]

This is a thin wrapper around `erch wiki html`.
EOF
  exit 0
fi

INPUT="${1:-}"
if [[ -z $INPUT || ! -f $INPUT ]]; then
  echo "Usage: erch md-to-html input.md [output.html]" >&2
  exit 1
fi

OUT="${2:-${INPUT%.*}.html}"
exec erch wiki html "$INPUT" -o "$OUT"
